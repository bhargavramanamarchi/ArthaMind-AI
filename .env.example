# ============================================================
# ArthaMind AI — Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys.
# Never commit your .env file to version control.
# ============================================================

# ── Required ─────────────────────────────────────────────────
# Google Gemini API Key (get from https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# ── Optional (Voice AI) ─────────────────────────────────────
# AssemblyAI API Key (get from https://www.assemblyai.com/dashboard)
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# Murf AI API Key (get from https://murf.ai/api)
MURF_API_KEY=your_murf_api_key_here

# ── Optional (Market Data) ──────────────────────────────────
# GoldAPI Key (get from https://www.goldapi.io/)
GOLDAPI_KEY=your_goldapi_key_here

# ── App Settings ─────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Gradio server settings
GRADIO_SERVER_PORT=7860
GRADIO_SHARE=false
